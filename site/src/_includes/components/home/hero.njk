<section class="hero-wrap" aria-labelledby="hero-title">
  <div class="site-shell hero-inner">
    <div class="hero-row">
      <img class="hero-ferris" src="/assets/images/ferris.svg" alt="Ferris mascot" />

      <h1 id="hero-title" class="hero">
        <span class="hero-line hero-line-1 hero-line-break">
          <em>{{ home.hero.brand | default("Zerobrew") }}</em>
          {{ home.hero.line1Suffix | default("is a drop-in replacement") }}
        </span>
        <span class="hero-line hero-line-2 hero-line-break">
          {{ home.hero.line2Prefix | default("for Homebrew, achieving") }}
          <strong>{{ home.hero.line2Highlight | default("20x/5x") }}</strong>
        </span>
        <span class="hero-line hero-line-3">{{ home.hero.line3 | default("the speed with the same packages.") }}</span>
      </h1>
    </div>
  </div>
  <img class="wave" src="/assets/images/wave.svg" alt="" aria-hidden="true" />
</section>
