<article class="bench-panel" id="benchmarks" aria-labelledby="bench-title-heading">
  <div class="panel-copy">
    <p class="panel-eyebrow">{{ home.sections.benchmarks.eyebrow }}</p>
  </div>

  <div class="bench-card card-shadow">
    <header class="bench-header">
      <h2 class="bench-title" id="bench-title-heading">{{ benchmarks.title }}</h2>
    </header>

    <div class="bench-list">
      {% for item in benchmarks.items %}
        <div class="bench-row" style="--bench-color: {{ item.color }}">
          <div class="bench-label">
            <span class="bench-name">{{ item.label }}</span>
            {% if item.tag %}
              <span class="bench-tag">{{ item.tag }}</span>
            {% endif %}
          </div>
          <div class="bench-bar">
            <span class="bench-fill" style="width: {{ item.width }}%;"></span>
            {% if item.speedup %}
              <span class="bench-speedup-text">{{ item.speedup }}</span>
            {% endif %}
          </div>
          <div class="bench-time">{{ item.time }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</article>
