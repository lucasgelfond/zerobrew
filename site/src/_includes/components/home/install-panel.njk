<article class="install-panel" id="install" aria-labelledby="install-title">
  <div class="panel-copy">
    <p class="panel-eyebrow">{{ home.sections.install.eyebrow }}</p>
    <p class="panel-description">{{ home.sections.install.body | safe }}</p>
  </div>

  <h2 id="install-title" class="sr-only">{{ install.title }}</h2>

  <div class="install-tabs">
    <div class="install-tab-group" role="tablist" aria-label="Install methods">
      {% for tab in install.tabs %}
        <button
          type="button"
          role="tab"
          class="install-tab{% if loop.first %} is-active{% endif %} card-shadow"
          data-command="{{ tab.command }}"
          aria-controls="install-command-code"
          aria-selected="{% if loop.first %}true{% else %}false{% endif %}"
        >
          {{ tab.name }}
        </button>
      {% endfor %}
    </div>

    <button class="install-copy card-shadow" type="button" aria-label="Copy install command">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <rect class="copy-front" x="8" y="8" width="13" height="13" rx="2"></rect>
        <rect x="3" y="3" width="13" height="13" rx="2"></rect>
      </svg>
    </button>
  </div>

  <div class="install-command card-shadow">
    <code id="install-command-code" aria-live="polite">{{ install.tabs[0].command }}</code>
  </div>

</article>
